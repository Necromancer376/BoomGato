{
  "name": "exploding-kittens-web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite --host 0.0.0.0 client",
    "typecheck": "tsc --noEmit",
    "build:client": "vite build client",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "npm run typecheck && npm run build:client && npm run build:server",
    "start": "node server-dist/server/index.js",
    "test": "vitest run",
    "fetch:cards": "tsx scripts/fetch-card-assets.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "cheerio": "^1.1.2",
    "concurrently": "^9.2.1",
    "express": "^5.1.0",
    "lucide-react": "^0.468.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vitest": "^3.2.4",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "jsdom": "^26.1.0"
  }
}
